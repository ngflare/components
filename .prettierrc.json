{
  "singleQuote": true,
  "printWidth": 100,
  "trailingComma": "es5",
  "quoteProps": "preserve",
  "semi": true,
  "bracketSpacing": true,
  "arrowParens": "avoid",
  "embeddedLanguageFormatting": "off",
  "overrides": [
    {
      "files": ["**/*.css", "**/*.scss", "**/*.html"],
      "options": {
        "singleQuote": false
      }
    }
  ]
}
